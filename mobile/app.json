{
  "expo": {
    "name": "detector-placas",
    "slug": "detector-placas",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "detectorplacas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Permite a la app acceder a la camara para detectar placas.",
        "NSMicrophoneUsageDescription": "Permite a la app usar el microfono para reproducir voz."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "permissions": [
        "CAMERA",
        "INTERNET",
        "android.permission.CAMERA"
      ],
      "package": "com.unab.detectorplacas",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permite a la app acceder a tu camara para fotografiar placas.",
          "recordAudioAndroid": false
        }
      ],
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "20b4f6a5-d2af-4d47-854d-5850718a4c51"
      }
    },
    "owner": "leydymacareo"
  }
}
